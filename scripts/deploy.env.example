# VPS connection
VPS_HOST=your-vps-ip-or-hostname
VPS_USER=root
SSH_PORT=22

# Auth — SSH key or SSH agent (no password auth supported)
SSH_KEY=~/.ssh/id_rsa

# Docker image
IMAGE_NAME=ebuchi-server
IMAGE_TAG=latest

# Container
CONTAINER_NAME=ebuchi-server

# Directory on the VPS where infra files are synced (used by --setup-infra)
REMOTE_DIR=/opt/ebuchi

# Path to .env file on the VPS — repo root .env is pushed here with --sync-env
REMOTE_ENV_FILE=/opt/ebuchi/.env

# Used only with --sync-env flag; defaults to repo root .env
LOCAL_ENV_FILE=.env

# Target platform — change to linux/arm64 for ARM VPS
PLATFORM=linux/amd64

# Ports to open in UFW (used by setup-firewall.sh) — comma-separated, no spaces
# Internal-only ports (Redis, Lavalink, Prometheus) should NOT be listed here
FIREWALL_PORTS=PORT,GRAFANA_PORT,GLITCHTIP_PORT
